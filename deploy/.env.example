# 배포용 공개 주소
FRONTEND_PUBLIC_HOST=market-fit.jongchoi.com
FRONTEND_PUBLIC_PORT=2080
FRONTEND_PUBLIC_ORIGIN=http://market-fit.jongchoi.com:2080

API_PUBLIC_HOST=api.market-fit.jongchoi.com
API_PUBLIC_PORT=2081
API_PUBLIC_ORIGIN=http://api.market-fit.jongchoi.com:2081

AUTH_PUBLIC_HOST=auth.market-fit.jongchoi.com
AUTH_PUBLIC_PORT=2081
AUTH_PUBLIC_ORIGIN=http://auth.market-fit.jongchoi.com:2081

# Traefik CORS 허용 origin 목록이다. 쉼표로 여러 개를 넣을 수 있다.
TRAEFIK_CORS_ORIGINS=http://market-fit.jongchoi.com:2080

# Authentik / OAuth
AUTHENTIK_TAG=2026.5
AUTHENTIK_SECRET_KEY=CHANGE_ME_60+_CHARS_RANDOM_VALUE
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_BOOTSTRAP_EMAIL=example@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME_BOOTSTRAP_PASSWORD
AUTHENTIK_BOOTSTRAP_TOKEN=CHANGE_ME_BOOTSTRAP_TOKEN
AUTHENTIK_CLIENT_ID=pickle-web
AUTHENTIK_CLIENT_SECRET=CHANGE_ME_AUTHENTIK_CLIENT_SECRET
AUTHENTIK_SERVICE_ROLE_KEY=CHANGE_ME_60_CHARS_RANDOM_SERVICE_ROLE_KEY
AUTHENTIK_BETTER_AUTH_CALLBACK_URL=http://market-fit.jongchoi.com:2080/api/auth/oauth2/callback/authentik
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# 데이터베이스 비밀번호
AUTHENTIK_DB_PASSWORD=CHANGE_ME_AUTHENTIK_DB_PASSWORD
BACKEND_DB_POSTGRES_PASSWORD=CHANGE_ME_BACKEND_DB_POSTGRES_PASSWORD
COMMUNITY_DB_NAME=demo
# community-service application.yaml이 현재 demo/demo를 기본 계약으로 사용한다.
COMMUNITY_DB_USER=demo
COMMUNITY_DB_PASSWORD=demo
ONBOARDING_DB_NAME=onboarding
ONBOARDING_DB_USER=onboarding
ONBOARDING_DB_PASSWORD=CHANGE_ME_ONBOARDING_DB_PASSWORD
AGENT_DB_NAME=agent
AGENT_DB_USER=agent
AGENT_DB_PASSWORD=CHANGE_ME_AGENT_DB_PASSWORD
POST_DB_NAME=post
POST_DB_USER=post
POST_DB_PASSWORD=CHANGE_ME_POST_DB_PASSWORD
MARKET_DB_USER=market
MARKET_DB_PASSWORD=CHANGE_ME_MARKET_DB_PASSWORD
FRANCHISE_DB_USER=franchise
FRANCHISE_DB_PASSWORD=CHANGE_ME_FRANCHISE_DB_PASSWORD

# 메시징 / 스토리지
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
MINIO_ROOT_USER=demo
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD
S3_REGION=us-east-1
S3_BUCKET=pickle-post-images
S3_PRESIGNED_URL_EXPIRATION_SECONDS=600

# post-service
POST_NOTIFICATION_MODE=RABBIT
POST_NOTIFICATION_EXCHANGE=pickly.events.exchange
OPENAI_API_KEY=
POST_LLM_PROVIDER=OPENAI
POST_LLM_MODEL=gpt-4o-mini
POST_LLM_TIMEOUT_SECONDS=30

# franchise-service ingest를 직접 켤 때만 사용한다.
FRANCHISE_INGEST_YEAR=2025
FRANCHISE_INGEST_NUM_OF_ROWS=1000
STARTUP_COST_SERVICE_KEY=
BRAND_FRCS_STATUS_SERVICE_KEY=

# agent-service
SEARXNG_SEARCH_URL=https://metasearch.example.com/search
SEARXNG_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
GEMINI_API_KEY=

# onboarding-service 학습 파라미터
ONBOARDING_TWO_TOWER_EPOCHS=20
ONBOARDING_CATEGORY_TOWER_EPOCHS=24
ONBOARDING_CATEGORY_DATA_MODE=sample
ONBOARDING_SERVICE_DEMO_AUTH_USER_UUID=123e4567-e89b-12d3-a456-426614174000
